TELEGRAM_TOKEN=
# Your Telegram chat id (single-user). Get it from @userinfobot. Required in telegram mode.
TELEGRAM_CHAT_ID=
AI_GATEWAY_API_KEY=
TAVILY_API_KEY=
LMNR_PROJECT_API_KEY=
# The agent's working dir (bash cwd + file-tool root). Default ./workspace.
WORKSPACE_DIR=
# The memory unit (notes/conversations/reminders/MEMORY.md). Default WORKSPACE_DIR/memory.
MEMORY_DIR=
# Optional: Composio for Gmail + Google Calendar tools. Both must be set to enable.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=
